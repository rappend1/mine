/* ── HELPERS ── */
function pClass(p){return p.startsWith('GRATIS')?'pt-free':p==='--'||p==='—'?'pt-na':'pt-paid'}
function imgTag(id,h,cls,style){
const u=PH[id];
return u?`<img class="${cls}" src="${u}" alt="" loading="lazy" style="${style||''}" onerror="this.closest('.${cls.split(' ')[0]}').innerHTML='<div style=\\'height:${h||176}px;display:flex;align-items:center;justify-content:center;font-size:44px;background:var(--s3)\\'>📍</div>'">`:`<div style="height:${h||176}px;display:flex;align-items:center;justify-content:center;font-size:44px;background:var(--s3)">📍</div>`;
}

/* ── CARD HTML ── */
function cardH(p){
const pc=pClass(p.price);
const skyTag=p.sky==='con'?'<div class="sky-tag sky-con">Solo CON Skyview</div>':p.sky==='sin'?'<div class="sky-tag sky-sin">Solo SIN Skyview</div>':'';
return `<div class="card">
<div class="card-img">
${imgTag(p.id,176,'card-img','')}
<div class="price-tag ${pc}">${p.price}</div>
${skyTag}
</div>
<div class="card-body">
<div class="card-name">${p.name}</div>
<div class="card-desc">${p.desc}</div>
<div class="why">${p.why}</div>
<div class="card-foot">
<a class="mlink" href="${p.maps}" target="_blank">
<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
<span class="mlink-txt">${p.addr}</span>
</a>
<div class="cpill">${CE[p.cat]||''} ${CL[p.cat]||p.cat}</div>
</div>
</div>
</div>`;
}

/* ── RENDER PLACES ── */
function renderPlaces(){
const out=document.getElementById('places-out');
const filt=PLACES.filter(p=>{
if(ST.dayF!=='all'&&p.day!==ST.dayF)return false;
if(p.sky==='con'&&ST.skyF==='sin')return false;
if(p.sky==='sin'&&ST.skyF==='con')return false;
return true;
});
if(!filt.length){out.innerHTML='<div class="empty"><div class="empty-icon">🔍</div><p class="empty-txt">No hay lugares con esos filtros</p></div>';return;}
if(ST.dayF!=='all'){
out.innerHTML=`<div class="cards">${filt.map(cardH).join('')}</div>`;
} else {
const days=[...new Set(filt.map(p=>p.day))].sort((a,b)=>a-b);
out.innerHTML=days.map(d=>{
const pl=filt.filter(p=>p.day===d);
const col=DC[d]||'#888';
return `<div class="day-block">
<div class="day-hdr">
<div class="day-line" style="background:${col}"></div>
<div>
<div class="day-num">Día ${d===0?'Extra':d}</div>
<div class="day-name">${DN[d]}</div>
</div>
<div class="day-badge" style="background:${col}22;color:${col}">${pl.length} lugar${pl.length>1?'es':''}</div>
</div>
<div class="cards">${pl.map(cardH).join('')}</div>
</div>`;
}).join('');
}
}
function fDay(d,btn){
ST.dayF=d;
document.querySelectorAll('#sec-lugares .fb:not([id^=sky])').forEach(b=>b.classList.remove('on'));
btn.classList.add('on');renderPlaces();
}
function fSky(s,btn){
ST.skyF=s;
['sky-a','sky-c','sky-s'].forEach(id=>{const el=document.getElementById(id);if(el){el.classList.remove('sky-on');el.classList.remove('on');}});
btn.classList.add('sky-on');renderPlaces();
}

