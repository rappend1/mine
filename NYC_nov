function img(id,h){const u=PH[id];return u?`<img src="${u}" alt="" loading="lazy" style="width:100%;height:${h}px;object-fit:cover;display:block" onerror="this.style.display='none'">`:`<div style="height:${h}px;display:flex;align-items:center;justify-content:center;font-size:46px;background:#EDE7DC">${CAT[PL.find(p=>p.id===id)||{cat:'icono'}]||'📍'}</div>`;}
function ptag(p){return p.startsWith('GRATIS')?'pt-free':p==='--'||p==='—'?'pt-na':'pt-paid';}

function cardH(p){
  const pc=ptag(p.price);
  const st=p.sky==='con'?'<div class="stag s-con">Solo CON Skyview</div>':p.sky==='sin'?'<div class="stag s-sin">Solo SIN Skyview</div>':'';
  return `<div class="card">
    <div class="cimg">
      ${img(p.id,190)}
      ${pc!=='pt-na'?`<div class="ptag ${pc}">${p.price}</div>`:''}${st}
    </div>
    <div class="cbody">
      <div class="cname">${p.name}</div>
      <div class="cdesc">${p.desc}</div>
      <div class="cwhy"><span class="cwhy-ic">↳</span><span class="cwhy-t">${p.why}</span></div>
      <div class="cfoot">
        <a class="mlink" href="${p.maps}" target="_blank">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="mlink-t">${p.addr}</span>
        </a>
        <div class="cpill">${CAT[p.cat]||'📍'} ${CATL[p.cat]||p.cat}</div>
      </div>
    </div>
  </div>`;
}

function rPL(){
  const out=document.getElementById('pl-out');
  const f=PL.filter(p=>{
    if(ST.dF!=='all'&&p.day!==ST.dF)return false;
    if(p.sky==='con'&&ST.sF==='sin')return false;
    if(p.sky==='sin'&&ST.sF==='con')return false;
    return true;
  });
  if(!f.length){out.innerHTML='<div class="empty"><div class="empty-ic">🔍</div><div class="empty-t">Sin resultados</div><p class="empty-s">Probá otro filtro</p></div>';return;}
  if(ST.dF!=='all'){out.innerHTML=`<div class="cgrid">${f.map(cardH).join('')}</div>`;return;}
  const days=[...new Set(f.map(p=>p.day))].sort((a,b)=>a-b);
  out.innerHTML=days.map(d=>{
    const pl=f.filter(p=>p.day===d);
    const c=DC[d]||'#888';
    return `<div class="dblock">
      <div class="dhdr">
        <div class="dstripe" style="background:${c}"></div>
        <div class="dinfo"><div class="dlbl">Día ${d===0?'Extra':d}</div><div class="dname">${DN[d]}</div></div>
        <div class="dcnt" style="background:${c}18;color:${c}">${pl.length} lugar${pl.length>1?'es':''}</div>
      </div>
      <div class="cgrid">${pl.map(cardH).join('')}</div>
    </div>`;
  }).join('');
}

function fD(d,btn){ST.dF=d;document.querySelectorAll('#fbar-l .fb:not([id^=sk])').forEach(b=>b.classList.remove('on'));btn.classList.add('on');rPL();}
function fS(s,btn){ST.sF=s;['ska','skc','sks'].forEach(id=>{const el=document.getElementById(id);if(el){el.className='fb';if((s==='ambas'&&id==='ska')||(s==='con'&&id==='skc')||(s==='sin'&&id==='sks'))el.classList.add('sky-on');}});rPL();}

function setIt(v){
  ST.iV=v;
  const c=document.getElementById('ic-con'),s=document.getElementById('ic-sin');
  if(c)c.style.cssText=v==='con'?'flex:1;min-width:200px;padding:17px 20px;border-radius:16px;border:2px solid #2B5FA3;background:rgba(43,95,163,.04);cursor:pointer':'flex:1;min-width:200px;padding:17px 20px;border-radius:16px;border:2px solid #DDD8CE;background:transparent;cursor:pointer';
  if(s)s.style.cssText=v==='sin'?'flex:1;min-width:200px;padding:17px 20px;border-radius:16px;border:2px solid #2B5FA3;background:rgba(43,95,163,.04);cursor:pointer':'flex:1;min-width:200px;padding:17px 20px;border-radius:16px;border:2px solid #DDD8CE;background:transparent;cursor:pointer';
  rIT();
}
function tD(i){const b=document.getElementById('ib-'+i),ch=document.getElementById('ch-'+i);if(!b)return;const o=b.classList.toggle('open');if(ch)ch.style.transform=o?'rotate(180deg)':'rotate(0deg)';}
function rIT(){
  const base=[...ITIN_BASE];
  const d3=ST.iV==='con'?D3C:D3S;
  const all=[base[0],base[1],d3,...base.slice(2)].sort((a,b)=>a.day-b.day);
  document.getElementById('it-out').innerHTML=all.map((d,i)=>`
    <div class="itin-day">
      <div class="itin-hdr" onclick="tD(${i})">
        <div class="itin-stripe" style="background:${d.c}"></div>
        <div class="itin-info">
          <div class="itin-lbl">${d.lbl}</div>
          <div class="itin-title">📍 ${d.z}</div>
        </div>
        <div class="itin-bud ${d.bf==='fr'?'ib-fr':'ib-pa'}">${d.b}</div>
        <div class="itin-chev" id="ch-${i}">▼</div>
      </div>
      <div class="itin-body" id="ib-${i}">
        ${d.st.map((s,si)=>`<div class="itin-stop">
          <div class="it-tc"><div class="it-time">${s.t}</div></div>
          <div class="it-dc"><div class="it-dot" style="background:${d.c}"></div>${si<d.st.length-1?'<div class="it-line"></div>':''}</div>
          <div class="it-txt"><div class="it-pn">${s.p}</div><div class="it-note">${s.n}</div></div>
          ${s.pc!=='na'?`<div class="it-pr it-${s.pc}">${s.pr}</div>`:''}
        </div>`).join('')}
        <div class="it-geo">${d.geo}</div>
      </div>
    </div>`).join('');
}

function rOT(){
  document.getElementById('ot-out').innerHTML=`<div class="otras-grid">${OT.map(o=>`
    <div class="ot-c">
      <div class="ot-img">${PH[o.id]?`<img src="${PH[o.id]}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block">`:
      `<div class="ot-img-ph">${CAT[o.cat]||'📍'}</div>`}</div>
      <div class="ot-body">
        <div class="ot-top"><div class="ot-n">${o.n}</div><div class="ot-pr ${o.pr.startsWith('GRATIS')?'fr':''}">${o.pr}</div></div>
        <div class="ot-desc">${o.d}</div>
        <div class="ot-why">↳ ${o.w}</div>
        <div class="ot-foot">
          <span class="ot-when">📅 ${o.when}</span>
          <a class="ot-map" href="${o.maps}" target="_blank"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Ver en mapa</a>
        </div>
      </div>
    </div>`).join('')}</div>`;
}

function rCO(){
  document.getElementById('ct-rows').innerHTML=CT.map(r=>`<div class="ct-row"><div class="ct-row-ic"><span class="ct-ico">${r[0]}</span><span class="ct-name">${r[1]}</span></div><div class="ct-pp">${r[2]}</div><div class="ct-x3">${r[3]}</div></div>`).join('')
  +`<div class="ct-row ct-sub"><div class="ct-row-ic"><span class="ct-ico">—</span><span class="ct-name" style="font-weight:700">Subtotal</span></div><div class="ct-pp">$877</div><div class="ct-x3">$2.631</div></div>`
  +`<div class="ct-row ct-tot"><div class="ct-row-ic"><span class="ct-ico" style="color:#C08A20">💰</span><span class="ct-name">TOTAL (sin vuelo ni hotel)</span></div><div class="ct-pp" style="color:#fff">~$957</div><div class="ct-x3" style="font-weight:900;color:#C08A20">~$2.870</div></div>`;
  document.getElementById('tips-saving').innerHTML=SAV.map(s=>`<div class="sav-item"><span class="sav-dot">→</span><span>${s}</span></div>`).join('');
}

function rTips(){
  const secs=[{k:'g',t:'Gastronomía — Lo que no se pueden ir sin probar',c:'#D63018'},{k:'l',t:'Logística — Los tips clave del viaje',c:'#2B5FA3'},{k:'co',t:'Compras — Dónde y qué llevarse',c:'#1A8A6E'}];
  document.getElementById('tips-out').innerHTML=secs.map(s=>`
    <div class="recs-ttl"><div class="recs-acc" style="background:${s.c}"></div>${s.t}</div>
    <div class="recs-grid">${TIPS[s.k].map(r=>`<div class="rec-c"><div class="rec-bar" style="background:${r.c}"></div><div class="rec-body"><div class="rec-eye" style="color:${r.c}">${r.t}</div><div class="rec-n">${r.n}</div><div class="rec-d">${r.d}</div>${r.pr!=='—'?`<div class="rec-pr">💰 ${r.pr}</div>`:''}</div></div>`).join('')}
    </div>`).join('');
}

function rVO(){
  const main=PL.filter(p=>p.day!==0);
  const days=[...new Set(main.map(p=>p.day))].sort((a,b)=>a-b);
  document.getElementById('vo-out').innerHTML=days.map(d=>{
    const pl=main.filter(p=>p.day===d);
    const dc=DC[d]||'#888';
    return `<div class="vb-day">
      <div class="dhdr" style="margin-bottom:13px"><div class="dstripe" style="background:${dc}"></div><div class="dname">${DN[d]}</div></div>
      ${pl.map(p=>{
        const v=ST.votes[p.id]||{};
        const yc=Object.values(v).filter(x=>x==='yes').length;
        const nc=Object.values(v).filter(x=>x==='no').length;
        const uc=3-yc-nc;
        return `<div class="vcard">
          <div class="vcard-top">
            <div class="vph">${CAT[p.cat]||'📍'}</div>
            <div class="vinfo">
              <div class="vn">${p.name}</div>
              <div class="vm">${p.price} · ${DN[p.day].split(' — ')[0]}</div>
              <div class="vtally"><span class="tv">✓ Van: ${yc}</span><span class="tn">✗ Pasan: ${nc}</span><span class="tna">• Pendiente: ${uc}</span></div>
              <div class="vbar"><div class="vfill" style="width:${Math.round(yc/3*100)}%"></div></div>
            </div>
          </div>
          <div class="voters">
            ${['reni','mateo','nico'].map(u=>{const u2=U[u],cur=v[u];return `<div class="voter">
              <div class="vav" style="background:${u2.c};color:#fff">${u2.i}</div>
              <div class="vnm">${u2.n}</div>
              <div class="vbtns">
                <button class="vb${cur==='yes'?' vy':''}" onclick="dV('${p.id}','${u}','yes')">Voy</button>
                <button class="vb${cur==='no'?' vn2':''}" onclick="dV('${p.id}','${u}','no')">Paso</button>
              </div>
            </div>`;}).join('')}
          </div>
        </div>`;
      }).join('')}
    </div>`;
  }).join('');
}
function dV(pid,u,v){if(!ST.votes[pid])ST.votes[pid]={};ST.votes[pid][u]=ST.votes[pid][u]===v?null:v;rVO();}

function rCA(){
  document.getElementById('ca-out').innerHTML=PL.filter(p=>p.day!==0).map(p=>{
    const revs=ST.revs[p.id]||[];
    const avg=revs.length?(revs.reduce((a,r)=>a+r.s,0)/revs.length).toFixed(1):null;
    const cur=ST.stars[p.id]||0;
    const who=ST.whoR[p.id]||'reni';
    return `<div class="racard">
      <div class="ra-top">
        <div class="ra-ph">${CAT[p.cat]||'📍'}</div>
        <div>
          <div class="ra-n">${p.name}</div>
          <div class="ra-avg">${avg?`⭐ ${avg}/5 — ${revs.length} reseña${revs.length!==1?'s':''}`:' Sin calificación todavía'}</div>
        </div>
      </div>
      <div class="stars">${[1,2,3,4,5].map(n=>`<span class="star${cur>=n?' lit':''}" data-pid="${p.id}" data-n="${n}" onclick="sS('${p.id}',${n})" onmouseover="hS('${p.id}',${n})" onmouseout="rS('${p.id}')">★</span>`).join('')}</div>
      <div class="wpills">${Object.entries(U).map(([k,u])=>`<button class="wp${who===k?' on':''}" style="border-color:${u.c};color:${u.c};background:${who===k?u.c+'15':'transparent'}" onclick="sWR('${p.id}','${k}')">${u.n}</button>`).join('')}</div>
      <textarea class="rta" id="rta-${p.id}" rows="2" placeholder="¿Qué les pareció?..."></textarea>
      <button class="sbtn" onclick="svRev('${p.id}')">Guardar reseña</button>
      ${revs.length?`<div class="rev-list">${revs.map(r=>`<div class="rev">
        <div class="rev-who"><div class="rav" style="background:${U[r.u].c};color:#fff">${U[r.u].i}</div><span class="rnm">${U[r.u].n}</span><span class="rstars">${'★'.repeat(r.s)}${'☆'.repeat(5-r.s)}</span><span class="rdate">${r.d}</span></div>
        ${r.t?`<div class="rtxt">${r.t}</div>`:''}
      </div>`).join('')}</div>`:''}
    </div>`;
  }).join('');
}
function hS(pid,n){document.querySelectorAll(`[data-pid="${pid}"]`).forEach(s=>s.classList.toggle('lit',+s.dataset.n<=n));}
function rS(pid){const c=ST.stars[pid]||0;document.querySelectorAll(`[data-pid="${pid}"]`).forEach(s=>s.classList.toggle('lit',+s.dataset.n<=c));}
function sS(pid,n){ST.stars[pid]=n;rS(pid);}
function sWR(pid,u){ST.whoR[pid]=u;rCA();}
function svRev(pid){
  const ta=document.getElementById('rta-'+pid);
  const s=ST.stars[pid]||0,t=ta?ta.value.trim():'',u=ST.whoR[pid]||'reni';
  if(!s&&!t)return;
  if(!ST.revs[pid])ST.revs[pid]=[];
  ST.revs[pid].push({u,s,t,d:new Date().toLocaleDateString('es-AR')});
  ST.stars[pid]=0;if(ta)ta.value='';
  rCA();
}

function tW(u){
  const i=ST.whoSel.indexOf(u);
  if(i>-1)ST.whoSel.splice(i,1);else ST.whoSel.push(u);
  ['reni','mateo','nico'].forEach(usr=>{const b=document.getElementById('wwho-'+usr);if(b)b.style.opacity=ST.whoSel.includes(usr)?'1':'0.35';});
}
function aW(){
  const n=document.getElementById('wn').value.trim(),a=document.getElementById('wa').value.trim(),c=document.getElementById('wc').value,m=document.getElementById('wm').value.trim(),t=document.getElementById('wt').value.trim();
  if(!n||!c){alert('Ponele un nombre y tipo al lugar');return;}
  ST.wish.unshift({id:'w'+Date.now(),n,a,c,m,t,who:[...ST.whoSel]});
  ['wn','wa','wm','wt'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('wc').value='';ST.whoSel=[];
  ['reni','mateo','nico'].forEach(u=>{const b=document.getElementById('wwho-'+u);if(b)b.style.opacity='0.35';});
  rWI();
}
function dWI(id){ST.wish=ST.wish.filter(w=>w.id!==id);rWI();}
function rWI(){
  const out=document.getElementById('wi-out');
  if(!ST.wish.length){out.innerHTML='<div class="empty"><div class="empty-ic">💡</div><div class="empty-t">Sin sugerencias todavía</div><p class="empty-s">¡Sean los primeros en agregar un lugar!</p></div>';return;}
  out.innerHTML=`<div class="wgrid">${ST.wish.map(w=>{
    const wc=WCAT[w.c]||{l:w.c,c:'#888'};
    const mu=w.m||(w.a?`https://maps.google.com/?q=${encodeURIComponent(w.n+' '+w.a)}`:'');
    return `<div class="wi">
      <div class="wi-top"><div class="wi-n">${w.n}</div><button class="wi-del" onclick="dWI('${w.id}')">×</button></div>
      ${w.a?`<div class="wi-a">📍 ${w.a}</div>`:''}
      ${w.t?`<div class="wi-note">"${w.t}"</div>`:''}
      <div class="wi-tags">
        <span class="wi-tag" style="background:${wc.c}15;color:${wc.c}">${wc.l}</span>
        ${w.who.map(u=>`<span class="wi-tag" style="background:${U[u].c}18;color:${U[u].c}">${U[u].n}</span>`).join('')}
      </div>
      ${mu?`<a class="wi-map" href="${mu}" target="_blank"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Ver en Google Maps</a>`:''}
    </div>`;
  }).join('')}</div>`;
}

function S(id,el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.sbi,.bni-item').forEach(s=>s.classList.remove('on'));
  document.getElementById('sec-'+id).classList.add('on');
  document.querySelectorAll(`[onclick="S('${id}',this)"]`).forEach(s=>s.classList.add('on'));
  if(id==='votos')rVO();
  else if(id==='cali')rCA();
  else if(id==='wish')rWI();
  else if(id==='itinerario')rIT();
  else if(id==='otras')rOT();
  else if(id==='tips')rTips();
  else if(id==='costos')rCO();
  window.scrollTo(0,0);
}
rPL();rWI();
</script>
</body>
</html>
