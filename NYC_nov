const out=document.getElementById('otras-out');
out.innerHTML=`<div class="rec-grid">${OTRAS.map(o=>`
<div class="rec-card">
<div class="rec-img">${PH[o.id]?`<img src="${PH[o.id]}" alt="${o.name}" loading="lazy" style="width:100%;height:100%;object-fit:cover">`:
`<div class="rec-img-ph">${CE[o.cat]||'📍'}</div>`}</div>
<div class="rec-body">
<div class="rec-name" style="font-size:14px;font-weight:700;color:var(--tx);margin-bottom:5px">${o.name}</div>
<div class="rec-desc">${o.desc}</div>
<div style="font-size:11px;color:var(--teal);margin-bottom:8px;font-weight:600">↳ ${o.why}</div>
<div class="rec-foot">
<span class="rec-tag" style="background:${o.cat_color}18;color:${o.cat_color}">${CE[o.cat]||''} ${CL[o.cat]||o.cat}</span>
<span class="rec-tag" style="background:var(--s3);color:var(--tx3)">📅 ${o.when}</span>
<span class="rec-tag" style="background:rgba(255,176,32,0.12);color:var(--gold)">💰 ${o.price}</span>
</div>
<a class="rec-addr" href="https://maps.google.com/?q=${encodeURIComponent(o.name+' '+o.addr)}" target="_blank">
<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
${o.addr}
</a>
</div>
</div>`).join('')}</div>`;
}

/* ── RECOMENDACIONES ── */
function renderRecs(){
const out=document.getElementById('recs-out');
const sections=[
{key:'gastronomia',title:'🍕 Gastronomía — Lo que no se pueden ir sin probar',color:'#ff3b5c'},
{key:'logistica',title:'✈️ Logística — Tips clave para el viaje',color:'#5b8fff'},
{key:'compras',title:'🛍️ Compras — Dónde y qué llevar',color:'#00e5a0'},
];
out.innerHTML=sections.map(sec=>`
<div class="rec-section-title">
<div class="rst-dot" style="background:${sec.color}"></div>
${sec.title}
</div>
<div class="rec-grid" style="margin-bottom:32px">${RECS[sec.key].map(r=>`
<div class="rec-card">
<div class="rec-body" style="padding:16px">
<div class="rec-eyebrow" style="color:${r.color}">${r.tag}</div>
<div class="rec-name">${r.name}</div>
<div class="rec-desc">${r.desc}</div>
<div class="rec-foot">
${r.price!=='—'?`<span class="rec-tag" style="background:rgba(255,176,32,0.12);color:var(--gold)">💰 ${r.price}</span>`:''}
</div>
</div>
</div>`).join('')}
</div>`).join('');
}

/* ── VOTES ── */
function renderVotes(){
const out=document.getElementById('votes-out');
const main=PLACES.filter(p=>p.day!==0);
const days=[...new Set(main.map(p=>p.day))].sort((a,b)=>a-b);
out.innerHTML=days.map(d=>{
const pl=main.filter(p=>p.day===d);
const col=DC[d]||'#888';
return `<div style="margin-bottom:24px">
<div class="day-hdr">
<div class="day-line" style="background:${col}"></div>
<div class="day-name">${DN[d]}</div>
</div>
${pl.map(p=>{
const v=ST.votes[p.id]||{};
const yc=Object.values(v).filter(x=>x==='yes').length;
const nc=Object.values(v).filter(x=>x==='no').length;
const uc=3-yc-nc;
return `<div class="vote-card">
<div class="vote-top">
<div class="vote-img-ph">${CE[p.cat]||'📍'}</div>
<div class="vote-info">
<div class="vote-name">${p.name}</div>
<div class="vote-meta">${p.price}</div>
<div class="vote-tally">
<span class="tv">✓ Van: ${yc}</span>
<span class="tn">✗ Pasan: ${nc}</span>
<span class="tna">• Pendiente: ${uc}</span>
</div>
</div>
</div>
<div class="vote-row">
${['reni','mateo','nico'].map(u=>{
const u2=USERS[u];const cur=v[u];
return `<div class="voter">
<div class="vav" style="background:${u2.color};color:${u2.tc}">${u2.init}</div>
<div class="vname">${u2.name}</div>
<div class="vbtns">
<button class="vb${cur==='yes'?' vy':''}" onclick="doVote('${p.id}','${u}','yes')">Voy</button>
<button class="vb${cur==='no'?' vn':''}" onclick="doVote('${p.id}','${u}','no')">Paso</button>
</div>
</div>`;
}).join('')}
</div>
</div>`;
}).join('')}
</div>`;
}).join('');
}
function doVote(pid,u,v){
if(!ST.votes[pid])ST.votes[pid]={};
ST.votes[pid][u]=ST.votes[pid][u]===v?null:v;
renderVotes();
}

/* ── RATINGS ── */
function renderRatings(){
const out=document.getElementById('ratings-out');
out.innerHTML=PLACES.filter(p=>p.day!==0).map(p=>{
const revs=ST.reviews[p.id]||[];
const avg=revs.length?(revs.reduce((a,r)=>a+r.s,0)/revs.length).toFixed(1):null;
const cur=ST.ratings[p.id]||0;
const who=ST.whoRating[p.id]||'reni';
return `<div class="rating-card">
<div class="rating-top">
<div class="rating-img-ph">${CE[p.cat]||'📍'}</div>
<div class="rating-info">
<div class="rating-name">${p.name}</div>
<div class="rating-avg">${avg?`⭐ ${avg}/5 — ${revs.length} reseña${revs.length!==1?'s':''}`:' Sin calificación todavía'}</div>
</div>
</div>
<div class="stars">${[1,2,3,4,5].map(n=>`<span class="star${cur>=n?' lit':''}" onclick="setStar('${p.id}',${n})" data-pid="${p.id}" data-n="${n}">★</span>`).join('')}</div>
<div class="who-row-r">
${['reni','mateo','nico'].map(u=>`<button class="who-rbtn${who===u?' on':''}" style="background:${USERS[u].color}18;border-color:${USERS[u].color};color:${USERS[u].color}" onclick="setWhoR('${p.id}','${u}')">${USERS[u].name}</button>`).join('')}
</div>
<textarea class="rtextarea" id="rta-${p.id}" rows="2" placeholder="¿Qué les pareció? Dejen su experiencia..."></textarea>
<button class="save-btn" onclick="saveReview('${p.id}')">Guardar reseña</button>
${revs.length?`<div class="review-list">${revs.map(r=>`<div class="review-item">
<div class="review-who">
<div class="review-av" style="background:${USERS[r.u].color};color:${USERS[r.u].tc}">${USERS[r.u].init}</div>
<span class="review-uname">${USERS[r.u].name}</span>
<span class="review-stars">${'★'.repeat(r.s)}${'☆'.repeat(5-r.s)}</span>
<span class="review-date">${r.d}</span>
</div>
${r.t?`<div class="review-txt">${r.t}</div>`:''}
</div>`).join('')}</div>`:''}
</div>`;
}).join('');
}
function setStar(pid,n){
ST.ratings[pid]=n;
document.querySelectorAll(`[data-pid="${pid}"]`).forEach(s=>s.classList.toggle('lit',+s.dataset.n<=n));
}
function setWhoR(pid,u){
ST.whoRating[pid]=u;renderRatings();
}
function saveReview(pid){
const ta=document.getElementById('rta-'+pid);
const s=ST.ratings[pid]||0;
const t=ta?ta.value.trim():'';
const u=ST.whoRating[pid]||'reni';
if(!s&&!t)return;
if(!ST.reviews[pid])ST.reviews[pid]=[];
ST.reviews[pid].push({u,s,t,d:new Date().toLocaleDateString('es-AR')});
ST.ratings[pid]=0;
if(ta)ta.value='';
renderRatings();
}

/* ── WISHLIST ── */
function toggleWho(u){
const i=ST.whoSel.indexOf(u);
if(i>-1)ST.whoSel.splice(i,1);else ST.whoSel.push(u);
['reni','mateo','nico'].forEach(usr=>{
const b=document.getElementById('wwho-'+usr);
if(b){b.classList.toggle('on',ST.whoSel.includes(usr));}
});
}
const WCAT_L={comida:"🍕 Para comer",compras:"🛍️ Compras",museo:"🎨 Museo",barrio:"🚶 Barrio",bar:"🍸 Bar / nocturna",espectaculo:"🎭 Show",mirador:"🏙️ Mirador",parque:"🌿 Parque",otro:"📍 Otro"};
const WCAT_C={comida:"#ff3b5c",compras:"#00e5a0",museo:"#a070ff",barrio:"#ffb020",bar:"#a070ff",espectaculo:"#ff3b5c",mirador:"#5b8fff",parque:"#00e5a0",otro:"#5c5a80"};
function addWish(){
const n=document.getElementById('wn').value.trim();
const a=document.getElementById('wa').value.trim();
const c=document.getElementById('wc').value;
const m=document.getElementById('wm').value.trim();
const t=document.getElementById('wt').value.trim();
if(!n||!c){alert('Ponele un nombre y tipo al lugar');return;}
ST.wishlist.unshift({id:'w'+Date.now(),n,a,c,m,t,who:[...ST.whoSel]});
['wn','wa','wm','wt'].forEach(id=>document.getElementById(id).value='');
document.getElementById('wc').value='';
ST.whoSel=[];
['reni','mateo','nico'].forEach(u=>{const b=document.getElementById('wwho-'+u);if(b)b.classList.remove('on');});
renderWish();
}
function delWish(id){ST.wishlist=ST.wishlist.filter(w=>w.id!==id);renderWish();}
function renderWish(){
const out=document.getElementById('wish-out');
if(!ST.wishlist.length){
out.innerHTML='<div class="empty"><div class="empty-icon">💡</div><p class="empty-txt">Todavía no hay sugerencias. ¡Sean los primeros!</p></div>';return;
}
out.innerHTML=`<div class="wish-list">${ST.wishlist.map(w=>{
const col=WCAT_C[w.c]||'#888';
const mUrl=w.m||(w.a?`https://maps.google.com/?q=${encodeURIComponent(w.n+' '+w.a)}`:'');
return `<div class="wish-item">
<div class="wi-top"><div class="wi-name">${w.n}</div><button class="wi-del" onclick="delWish('${w.id}')">×</button></div>
${w.a?`<div class="wi-addr">📍 ${w.a}</div>`:''}
${w.t?`<div class="wi-note">${w.t}</div>`:''}
<div class="wi-tags">
<span class="wi-tag" style="background:${col}18;color:${col}">${WCAT_L[w.c]||w.c}</span>
${w.who.map(u=>`<span class="wi-tag" style="background:${USERS[u].color}18;color:${USERS[u].color}">${USERS[u].name}</span>`).join('')}
</div>
${mUrl?`<a class="wi-maps" href="${mUrl}" target="_blank">
<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
Ver en Google Maps
</a>`:''}
</div>`;
}).join('')}</div>`;
}

/* ── TABS ── */
function showTab(id,tab){
document.querySelectorAll('.section').forEach(s=>s.classList.remove('on'));
document.getElementById('sec-'+id).classList.add('on');
document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
tab.classList.add('on');
if(id==='votos')renderVotes();
if(id==='calificaciones')renderRatings();
if(id==='wishlist')renderWish();
if(id==='itinerario')renderItin();
if(id==='otras')renderOtras();
if(id==='recomendaciones')renderRecs();
}

/* ── INIT ── */
renderPlaces();renderWish();
</script>
</body>
</html>
