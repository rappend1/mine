  {id:"p30",day:7,cat:"especial",sky:null,extra:false,name:"Macy's Thanksgiving Parade 100 Aniversario",price:"GRATIS",addr:"Central Park West y 77th St, NY",maps:"https://maps.google.com/?q=Macys+Thanksgiving+Day+Parade+Central+Park+West+New+York",img:"https://images.unsplash.com/photo-1576867757603-05b134ebc379?w=500&q=80",desc:"El desfile mas famoso de los Estados Unidos en su edicion numero 100. Globos gigantes, carrozas musicales, bandas de todo el pais y artistas en vivo.",why:"El 100 aniversario es un evento historico. Es la unica vez que pueden estar en el centenario del Macy's Parade."},
