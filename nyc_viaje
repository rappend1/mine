  {id:"p27",day:6,cat:"museo",sky:null,extra:false,name:"American Museum of Natural History",price:"~$35 c/u",addr:"200 Central Park W, NY 10024",maps:"https://maps.google.com/?q=American+Museum+Natural+History+200+Central+Park+W+New+York",img:"https://images.unsplash.com/photo-1565799743361-456e3a9e59e8?w=500&q=80",desc:"El museo de historia natural mas grande del mundo. El dinosaurio de 37 metros y la ballena azul de 29 metros colgando del techo son los highlights.",why:"La ballena azul colgando del techo es una de las imagenes mas iconicas de todos los museos del mundo."},
