const CE={hotel:"🏨",mirador:"🏙️",museo:"🎨",barrio:"🚶",parque:"🌿",gastronomia:"🍕",restaurante:"🍽️",compras:"🛍️",especial:"⭐",historia:"🏛️",bar:"🍸",espectaculo:"🎭",cultural:"📚",icono:"📍"};
const CN={hotel:"Hotel",mirador:"Mirador",museo:"Museo",barrio:"Barrio",parque:"Parque",gastronomia:"Gastronomia",restaurante:"Restaurante",compras:"Compras",especial:"Especial",historia:"Historia",bar:"Bar / Rooftop",espectaculo:"Espectaculo",cultural:"Cultural",icono:"Icono NYC"};
const TC={food:{l:"Para comer",c:"wt-food"},shopping:{l:"Compras",c:"wt-shopping"},museum:{l:"Museo / cultura",c:"wt-museum"},bar:{l:"Bar / noche",c:"wt-bar"},attraction:{l:"Atraccion",c:"wt-attraction"},other:{l:"Otro",c:"wt-other"}};

let fd="all",fc="all",fs="ambas",cu=null,wu=null;
function loadST(){try{const s=JSON.parse(localStorage.getItem("nyc2026")||"{}");return{r:s.r||{},c:s.c||{},v:s.v||{},w:s.w||[]};}catch{return{r:{},c:{},v:{},w:[]};}}
function saveST(){localStorage.setItem("nyc2026",JSON.stringify(ST));}
let ST=loadST();

function showTab(id,btn){
  document.querySelectorAll(".page-section").forEach(s=>s.classList.remove("visible"));
  document.querySelectorAll(".nav-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById("tab-"+id).classList.add("visible");
  btn.classList.add("active");
  if(id==="lugares")rPlaces();
  if(id==="itinerario")rItin();
  if(id==="votaciones")rVotes();
  if(id==="wishlist")rWish();
}

function fDay(d,btn){fd=d;document.querySelectorAll(".filter-bar .f-btn").forEach(b=>{if(["Todos los dias","Sab 22","Dom 23","Lun 24","Mar 25","Mie 26","Jue 27","Vie 28","Sab 29","Dom 29","Extras"].includes(b.textContent.trim()))b.classList.remove("on");});btn.classList.add("on");rPlaces();}
function fCat(c,btn){fc=c;document.querySelectorAll(".filter-bar .f-btn").forEach(b=>{if(["Todas","Miradores","Museos","Barrios","Compras","Gastronomia"].includes(b.textContent.trim()))b.classList.remove("on");});btn.classList.add("on");rPlaces();}
function fSky(v,btn){fs=v;document.querySelectorAll(".sky-opt").forEach(b=>b.classList.remove("on"));btn.classList.add("on");rPlaces();}

function filt(){return PLACES.filter(p=>{
  if(fd!=="all"&&p.day!==fd)return false;
  if(fc!=="all"&&p.cat!==fc&&!(fc==="gastronomia"&&p.cat==="restaurante"))return false;
  if(p.sky==="con"&&fs==="sin")return false;
  if(p.sky==="sin"&&fs==="con")return false;
  return true;
});}

function pc2(p){if(!p||p==="--"||p==="—")return"price-other";if(p.startsWith("GRATIS"))return"price-free";return"price-paid";}
function spc(p){if(!p||p==="--")return"sp-other";if(p.startsWith("GRATIS"))return"sp-free";return"sp-paid";}

function bStars(pid){
  const mk=cu?`${pid}_${cu}`:null;
  const mr=mk&&ST.r[mk]?ST.r[mk]:0;
  const all=Object.entries(ST.r).filter(([k])=>k.startsWith(pid+"_")).map(([,v])=>v);
  const avg=all.length?Math.round(all.reduce((a,b)=>a+b,0)/all.length*10)/10:0;
  let sh="";for(let i=1;i<=5;i++)sh+=`<span class="star${mr>=i?" lit":""}" onclick="rPl('${pid}',${i})">★</span>`;
  const revs=Object.entries(ST.c).filter(([k])=>k.startsWith(pid+"_")).map(([k,v])=>({u:k.split("_")[1],t:v}));
  const revH=revs.length?`<div class="reviews-list">${revs.map(rv=>{const uu=USERS[rv.u]||{name:rv.u,color:"#888",letter:"?"};const rs=ST.r[`${pid}_${rv.u}`]||0;return`<div class="review-item"><div class="review-header"><div class="review-avatar" style="background:${uu.color}">${uu.letter}</div><span class="review-name">${uu.name}</span><span class="review-stars">${"★".repeat(rs)}${"☆".repeat(5-rs)}</span></div><div class="review-text">${rv.t}</div></div>`;}).join("")}</div>`:"";
  return`<div class="rating-area">
    <div class="rating-label">${cu?`Calificar como ${USERS[cu].name}`:"Elegir usuario en Votaciones para calificar"}</div>
    <div class="stars-row" id="s-${pid}">${sh}</div>
    ${avg>0?`<div style="font-size:11px;color:var(--ink3);margin-bottom:6px;">Promedio: <strong style="color:var(--gold2)">${avg} ★</strong> (${all.length} voto${all.length>1?"s":""})</div>`:""}
    ${revH}
    ${cu?`<textarea class="comment-field" id="cm-${pid}" placeholder="Contar la experiencia..." rows="2"></textarea><button class="save-btn" onclick="sCmt('${pid}')">Guardar</button>`:""}
  </div>`;
}

function rPl(pid,stars){if(!cu){alert("Primero selecciona quien sos en la seccion Votaciones.");return;}ST.r[`${pid}_${cu}`]=stars;saveST();rPlaces();}
function sCmt(pid){if(!cu)return;const t=document.getElementById("cm-"+pid)?.value?.trim();if(!t)return;ST.c[`${pid}_${cu}`]=t;saveST();rPlaces();}

function pCard(p){
  const dm=DAY_META[p.day];const dc=dm?.color||"#888";
  const skyT=p.sky==="con"?`<span style="font-size:9px;background:#e8f0fd;color:#1a5cb8;padding:2px 6px;border-radius:8px;margin-left:4px;">Solo CON Skyview</span>`:p.sky==="sin"?`<span style="font-size:9px;background:#e8f5f0;color:#155a40;padding:2px 6px;border-radius:8px;margin-left:4px;">Solo SIN Skyview</span>`:"";
  return`<div class="pcard${p.extra?" extra-card":""}">
    <div class="pcard-img">
      <img src="${p.img}" alt="${p.name}" loading="lazy" onerror="this.style.display='none'">
      <span class="price-tag ${pc2(p.price)}">${p.price}</span>
      ${dm?`<span class="day-chip" style="background:${dc}">${dm.label}</span>`:""}
    </div>
    <div class="pcard-body">
      ${p.extra?`<div class="extra-badge">⚡ Si sobra tiempo</div>`:""}
      <div class="pcard-name">${p.name}${skyT}</div>
      <div class="pcard-cat">${CE[p.cat]||""} ${CN[p.cat]||p.cat}</div>
      <p class="pcard-desc">${p.desc}</p>
      <div class="pcard-why"><strong>Por que hacerlo</strong>${p.why}</div>
      <div class="pcard-footer">
        <a class="maps-btn" href="${p.maps}" target="_blank">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          ${p.addr}
        </a>
        ${bStars(p.id)}
      </div>
    </div>
  </div>`;
}

function rPlaces(){const f=filt();const c=document.getElementById("cards-container");if(!c)return;if(!f.length){c.innerHTML=`<div class="empty-state" style="grid-column:1/-1"><div class="big">🔍</div><p>No hay lugares con esos filtros.</p></div>`;return;}c.innerHTML=f.map(pCard).join("");}

function rItin(){
  const c=document.getElementById("itinerary-container");if(!c)return;
  c.innerHTML=ITINERARY.map(({day,stops})=>{
    const m=DAY_META[day];if(!m)return"";
    const sh=stops.map(s=>`<div class="stop-row"><div class="stop-time">${s.t}</div><div class="stop-body"><div class="stop-name">${s.n}</div>${s.note?`<div class="stop-note">${s.note}</div>`:""}</div><span class="stop-price ${spc(s.p)}">${s.p}</span></div>`).join("");
    const fh=m.food?`<div class="stop-food"><strong>Comer hoy</strong>${m.food}</div>`:"";
    return`<div class="day-block" id="db${day}"><div class="day-block-header" onclick="tDB(${day})"><div class="day-color-bar" style="background:${m.color}"></div><div class="day-block-info"><div class="day-block-name">${m.label}</div><div class="day-block-sub">${m.name}</div></div><div class="day-block-toggle">▾</div></div><div class="day-stops">${sh}${fh}</div></div>`;
  }).join("");
}
function tDB(d){document.getElementById("db"+d).classList.toggle("open");}

function selectUser(u,btn){cu=u;document.querySelectorAll(".user-btn[id^=ubtn]").forEach(b=>b.classList.remove("selected"));btn.classList.add("selected");const n=document.getElementById("vote-notice");n.textContent=`Votando y calificando como ${USERS[u].name}. Selecciona tus preferencias en los lugares.`;n.style.display="block";rVotes();rPlaces();}

function castVote(pid,v){if(!cu){alert("Primero selecciona tu nombre.");return;}if(!ST.v[pid])ST.v[pid]={};ST.v[pid][cu]=v;saveST();rVotes();}

function vCard(p){
  const vs=ST.v[p.id]||{};
  const vH=Object.entries(vs).map(([u,v])=>{const uu=USERS[u]||{name:u,color:"#888",letter:"?"};const e=v==="yes"?"✅":v==="no"?"❌":"🤔";return`<div style="display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--ink3);margin-right:8px;"><span style="display:inline-flex;width:18px;height:18px;border-radius:50%;background:${uu.color};color:#fff;font-size:9px;font-weight:800;align-items:center;justify-content:center;">${uu.letter}</span>${e}</div>`;}).join("");
  const mv=cu?vs[cu]:"";
  const dm=DAY_META[p.day];
  return`<div class="pcard"><div class="pcard-img"><img src="${p.img}" alt="${p.name}" loading="lazy" onerror="this.style.display='none'"><span class="price-tag ${pc2(p.price)}">${p.price}</span>${dm?`<span class="day-chip" style="background:${dm.color}">${dm.label}</span>`:""}</div><div class="pcard-body"><div class="pcard-name">${p.name}</div><div class="pcard-cat">${CE[p.cat]||""} ${CN[p.cat]||p.cat}</div><p class="pcard-desc" style="margin-bottom:10px;">${p.why}</p><div class="vote-row"><button class="vote-btn${mv==="yes"?" yes":""}" onclick="castVote('${p.id}','yes')">✅ Voy</button><button class="vote-btn${mv==="no"?" no":""}" onclick="castVote('${p.id}','no')">❌ No voy</button><button class="vote-btn${mv==="maybe"?" maybe":""}" onclick="castVote('${p.id}','maybe')">🤔 Tal vez</button></div>${vH?`<div style="margin-top:6px;">${vH}</div>`:""}</div></div>`;
}
function rVotes(){const c=document.getElementById("vote-cards");if(!c)return;c.innerHTML=PLACES.filter(p=>p.day>0).map(vCard).join("");}

function selectWishUser(u,btn){wu=u;document.querySelectorAll(".user-btn[id^=wubtn]").forEach(b=>b.classList.remove("selected"));btn.classList.add("selected");}
function addWishItem(){
  if(!wu){alert("Primero selecciona tu nombre.");return;}
  const name=document.getElementById("w-name").value.trim();
  const addr=document.getElementById("w-addr").value.trim();
  const type=document.getElementById("w-type").value;
  const note=document.getElementById("w-note").value.trim();
  if(!name){alert("Ponele un nombre al lugar.");return;}
  ST.w.push({id:"w"+Date.now(),u:wu,name,addr,type,note,date:new Date().toLocaleDateString("es-AR")});
  saveST();
  document.getElementById("w-name").value="";document.getElementById("w-addr").value="";document.getElementById("w-note").value="";
  rWish();
}
function delWish(id){ST.w=ST.w.filter(w=>w.id!==id);saveST();rWish();}
function rWish(){
  const c=document.getElementById("wishlist-container");if(!c)return;
  if(!ST.w.length){c.innerHTML=`<div class="empty-state"><div class="big">📋</div><p>Aun no hay lugares en el wishlist.<br>Sean los primeros en agregar algo.</p></div>`;return;}
  c.innerHTML=`<div class="wishlist-items">${ST.w.map(w=>{const uu=USERS[w.u]||{name:w.u,color:"#888",letter:"?"};const t=TC[w.type]||TC.other;const mu=`https://maps.google.com/?q=${encodeURIComponent(w.name+" "+w.addr)}`;return`<div class="wish-card"><div class="wish-card-top"><div class="wish-name">${w.name}</div><button class="wish-delete" onclick="delWish('${w.id}')">✕</button></div><span class="wish-type ${t.c}">${t.l}</span>${w.addr?`<div class="wish-addr">📍 ${w.addr}</div>`:""}${w.note?`<div class="wish-note">"${w.note}"</div>`:""}<div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;"><div class="wish-who"><div class="wish-avatar" style="background:${uu.color}">${uu.letter}</div><span style="font-size:11px;color:var(--ink3);">${uu.name} · ${w.date}</span></div><a href="${mu}" target="_blank" style="font-size:11px;color:var(--teal2);text-decoration:none;">Ver en Maps ↗</a></div></div>`;}).join("")}</div>`;
}
rPlaces();
</script>
</body>
</html>
