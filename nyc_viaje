  {id:"p32",day:8,cat:"compras",sky:null,extra:false,name:"Macy's Herald Square — Black Friday",price:"GRATIS entrar",addr:"151 W 34th St, NY 10001",maps:"https://maps.google.com/?q=Macys+Herald+Square+151+W+34th+St+New+York",img:"https://images.unsplash.com/photo-1605371924599-2d0365da1ae0?w=500&q=80",desc:"El Macys mas grande del mundo: 11 pisos, 200.000 m2. En Black Friday hay descuentos reales. Las escaleras de madera de 1902 son ya un atractivo.",why:"Una sola vez en la vida hay que entrar al Macys original. El Black Friday lo hace valer doble."},
  {id:"p33",day:8,cat:"compras",sky:null,extra:false,name:"5th Avenue — Black Friday",price:"GRATIS",addr:"5th Ave, NY 10019",maps:"https://maps.google.com/?q=Fifth+Avenue+New+York+Shopping",img:"https://images.unsplash.com/photo-1499092346589-b9b6be3e94b2?w=500&q=80",desc:"El Black Friday en la 5th Ave es el dia de mas actividad del ano. Descuentos en Apple, colas en Nike, vidrieras navidenas en su maximo esplendor.",why:"El mejor dia del ano para ver la 5th Ave. La energia del Black Friday mas las decoraciones navidenas: solo ocurre una vez al ano."},
  {id:"p34",day:8,cat:"espectaculo",sky:null,extra:false,name:"Broadway — Show en vivo",price:"~$70-120 c/u",addr:"Times Square Theater District, NY",maps:"https://maps.google.com/?q=TKTS+Times+Square+New+York+Broadway+tickets",img:"https://images.unsplash.com/photo-1585699324551-f6c309eedeca?w=500&q=80",desc:"Mas de 40 teatros en el Theater District. Comprar en TKTS de Times Square el mismo dia permite ahorrar hasta 50%. Hamilton, Wicked, El Rey Leon.",why:"Ir a Broadway en NYC es diferente a cualquier otro teatro del mundo. Una experiencia que te queda para toda la vida."},
